# syntax=docker/dockerfile:1
# Development image for the Vite dev server (hot reload). The source is
# bind-mounted by docker-compose.override.yml at runtime; only the dependency
# manifests are copied here so `node_modules` is built inside the container
# (and kept there via an anonymous volume so the bind mount doesn't shadow it).
FROM node:22-alpine

WORKDIR /app

COPY package.json package-lock.json* ./
RUN if [ -f package-lock.json ]; then npm ci; else npm install; fi

EXPOSE 5173

# vite.config.ts sets server.host:true; --host is belt-and-suspenders so the
# published port is reachable from the host.
CMD ["npm", "run", "dev", "--", "--host"]
