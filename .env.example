# Copy to .env and fill in real values:  cp .env.example .env
# .env is gitignored and is NEVER copied into the Docker image — compose
# injects it at runtime. The container-path/prod values (DB_STRING, UPLOADS_DIR,
# PORT, GO_ENV, COOKIE_SECURE) are pinned in docker-compose.yml and override
# whatever you set here, so for Docker you mainly need JWT_SECRET below.

# --- Required ----------------------------------------------------------------
# HS256 signing key. MUST be >= 32 bytes of entropy. Generate one with:
#   openssl rand -base64 48
# Do NOT reuse the throwaway secret from .env.test — that value is for tests
# only and is checked into the repo.
JWT_SECRET=

# --- Server ------------------------------------------------------------------
PORT=8080
GO_ENV=prod                       # "dev" or "prod"

# --- Storage (paths) ---------------------------------------------------------
# In Docker these are pinned to the /data volume by docker-compose.yml.
# For a bare `go run ./cmd/server` they default to ./vault.db and ./uploads.
DB_STRING=vault.db                # SQLite file path
UPLOADS_DIR=./uploads             # featured-image storage root

# --- JWT (have sane defaults; override only if needed) -----------------------
JWT_ISSUER=micro-blog
JWT_AUDIENCE=micro-blog-api
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# --- Cookies -----------------------------------------------------------------
# COOKIE_SECURE=true marks the refresh cookie Secure (HTTPS-only) and, in the
# server wiring, enables HSTS. Only set true when a TLS terminator (reverse
# proxy / cloud LB) sits in front of the container. The dev compose forces
# this to false for plain-HTTP localhost.
COOKIE_SECURE=true

# --- Admin seed (used by `migrate seed`, not the server) ---------------------
# Password for the seeded admin user. Defaults to "changeme" with a warning if
# unset — set a real value before running `docker compose run --rm api /app/migrate seed`.
ADMIN_SEED_PASSWORD=
